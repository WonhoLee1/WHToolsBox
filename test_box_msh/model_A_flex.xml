    <body name="CohDisp" pos="0 0 0.5">
      <freejoint/>
      <geom type="mesh" mesh="CohDisp_mesh" rgba="0.8 0.8 0.2 0.5" mass="1" group="2" contype="2" conaffinity="3"/>
